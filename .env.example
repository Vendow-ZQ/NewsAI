# NewsAI 环境变量配置文件
# 复制此文件为 .env 并填入你的实际密钥

# ==========================================
# 飞书配置（必填）
# ==========================================
# 飞书应用凭证（从飞书开放平台获取）
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书Base Token（从Base URL中获取）
# 格式如: XXXXXXXXXXXXXXXX
# 如果没有，运行bootstrap.py时会提示创建
LARK_BASE_APP_TOKEN=

# ==========================================
# LLM配置（必填）
# ==========================================
# 豆包2.0 API密钥（从火山方舟获取）
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 可选：其他OpenAI兼容API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# 模型配置（可选，保持默认即可）
# ==========================================
# 默认使用豆包2.0
DEFAULT_MODEL=doubao-2.0

# 超时时间（秒）
LLM_TIMEOUT=300

# ==========================================
# 项目配置（可选）
# ==========================================
# 日志级别: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# 是否使用Mock数据（测试用）
USE_MOCK=false

# 信源配置（可选）
# HackerNews、GitHub、Reddit等API密钥
HN_API_KEY=
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
